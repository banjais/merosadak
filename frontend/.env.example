# ===========================================
# MeroSadak Frontend - Environment Template
# ===========================================
# Copy this file to .env.development or .env.production
# and fill in the values. NEVER commit real secrets!

# API Configuration (single source of truth - includes /v1 prefix)
VITE_API_URL=http://localhost:4000/api/v1

# WebSocket
VITE_WS_URL=ws://localhost:4000/ws/live

# Google AI (Gemini) - Get from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (optional - only if using Firebase Auth/Analytics)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_BACKEND=https://your-project.web.app

# App Settings
VITE_APP_NAME=MeroSadak
VITE_DEFAULT_LANGUAGE=en
VITE_LOGIN_REQUIRED=false
VITE_ENABLE_GEOLOCATION=true
VITE_ENABLE_3D_MODE=false
VITE_USE_MOCK=false
VITE_ENABLE_SW=false
