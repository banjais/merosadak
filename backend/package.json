{
  "name": "sadaksathi-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsup src/index.ts --format esm --clean && npm run diag",
    "prestart": "npx kill-port 4000 || true",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start dist/index.js --name sadak-sathi-backend",
    "predev": "npx kill-port 4000 || true",
    "dev": "cross-env NODE_ENV=development tsup --watch --onSuccess \"node dist/index.js\"",
    "diag": "tsx src/scripts/diagnostics.ts",
    "predeploy": "npm run build",
    "lint": "eslint . --quiet",
    "format": "prettier --write .",
    "logs": "pm2 logs sadak-sathi-backend",
    "stop": "pm2 stop sadak-sathi-backend"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.4",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.0.1",
    "express-rate-limit": "^8.2.1",
    "fuse.js": "^7.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.15.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.16.0",
    "ioredis": "^5.9.2",
    "kill-port": "^2.0.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
