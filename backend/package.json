{
  "name": "merosadak-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "merge": "tsx src/scripts/mergeData.ts",
    "diag": "tsx src/scripts/diagnostics.ts",
    "validate-sheet": "tsx src/scripts/validateSheet.ts",
    "build": "cross-env NODE_ENV=production npm run clean && tsup && npm run diag",
    "build:dev": "npm run clean && tsup && npm run diag",
    "prestart": "npx kill-port 4000 || true",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "start:bg": "nohup node dist/index.js > server.log 2>&1 &",
    "predev": "npx kill-port 4000 || true",
    "dev": "cross-env NODE_ENV=development tsup --watch --onSuccess \"node dist/index.js\"",
    "deploy": "npm run stop:bg && npm run build && npm run start:bg",
    "lint": "eslint . --quiet",
    "format": "prettier --write .",
    "stop:bg": "npx kill-port 4000 || true"
  },
  "dependencies": {
    "@sentry/node": "^10.38.0",
    "@upstash/redis": "^1.36.2",
    "axios": "^1.13.6",
    "concurrently": "^9.1.0",
    "cors": "^2.8.6",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fuse.js": "^7.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "kill-port": "^2.0.1",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.15.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@sentry/profiling-node": "^10.38.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.19.11",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@upstash/redis": "^1.36.2",
    "eslint": "^9.16.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
