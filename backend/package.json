{
  "name": "merosadak-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "diag": "cross-env NODE_OPTIONS=--max-old-space-size=2048 tsx src/scripts/diagnostics.ts",
    "validate-sheet": "cross-env NODE_OPTIONS=--max-old-space-size=2048 tsx src/scripts/validateSheet.ts",
    "refresh-caches": "cross-env NODE_OPTIONS=--max-old-space-size=2048 tsx src/scripts/refreshCaches.ts",
    "build": "cross-env NODE_ENV=production npm run clean && tsup && cross-env NODE_ENV=production npm run diag",
    "deploy": "npm run build && npx wrangler deploy",
    "build:dev": "npm run clean && tsup && npm run diag",
    "prestart": "npx kill-port 4000 || true",
    "start": "node --max-old-space-size=2048 dist/index.js",
    "start:prod": "NODE_ENV=production node --max-old-space-size=2048 dist/index.js",
    "start:bg": "nohup node --max-old-space-size=2048 dist/index.js > server.log 2>&1 &",
    "predev": "npx kill-port 4000 || true",
    "dev": "cross-env NODE_ENV=development tsup --watch --onSuccess \"node --max-old-space-size=2048 dist/index.js\"",
    "lint": "eslint . --quiet",
    "format": "prettier --write .",
    "stop:bg": "npx kill-port 4000 || true"
  },
  "dependencies": {
    "@sentry/node": "^10.38.0",
    "@upstash/redis": "^1.36.2",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fuse.js": "^7.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "portfinder": "^1.0.32",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^6.4.17",
    "@types/ws": "^8.5.14",
    "eslint": "^9.39.2",
    "globals": "^14.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0",
    "web-push": "^3.6.7",
    "wrangler": "^4.13.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
