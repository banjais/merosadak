{
  "name": "merosadak-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "merge": "tsx src/scripts/mergeData.ts",
    "diag": "tsx src/scripts/diagnostics.ts",
    "validate-sheet": "tsx src/scripts/validateSheet.ts",
    "build": "cross-env NODE_ENV=production npm run clean && tsup && cross-env NODE_ENV=production npm run diag",
    "build:dev": "npm run clean && tsup && npm run diag",
    "prestart": "npx kill-port 4000 || true",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "start:bg": "nohup node dist/index.js > server.log 2>&1 &",
    "predev": "npx kill-port 4000 || true",
    "dev": "cross-env NODE_ENV=development tsup --watch --onSuccess \"node dist/index.js\"",
    "deploy": "npm run build && npx wrangler deploy", 
    "lint": "eslint . --quiet",
    "format": "prettier --write .",
    "stop:bg": "npx kill-port 4000 || true"
  },
  "dependencies": {
    "@sentry/node": "^10.38.0",
    "@upstash/redis": "^1.36.2",
    "axios": "^1.13.6",
    "concurrently": "^9.1.0",
    "cors": "^2.8.6",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fuse.js": "^7.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
