{
  "name": "sadaksathi-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "// --- DEVELOPMENT ---": "",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"bgBlue,bgMagenta\" \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "install-all": "npm install",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules",

    "// --- PRODUCTION ---": "",
    "build": "npm run build --workspaces --if-present",
    "start": "pm2 start ecosystem.config.yml",
    "stop": "pm2 stop all",
    "logs": "pm2 logs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "pm2": "^5.4.0" 
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "4.2.1",
    "leaflet": "1.9.4"
  }
}